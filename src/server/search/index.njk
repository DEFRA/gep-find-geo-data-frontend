{% extends 'layouts/page.njk' %}

{% block content %}
  <div class="defra-width-container govuk-!-margin-top-5">

    <div id="search-error-summary">
      {% include "search/_error-summary.njk" %}
    </div>

    <div id="search-status" role="status" aria-live="polite" aria-atomic="true" class="govuk-visually-hidden"></div>

    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl govuk-!-margin-bottom-4">{{ heading }}</h1>
      </div>
    </div>

    <form action="/" method="GET" role="search"
          aria-label="Search datasets"
          data-module="app-search"
          data-endpoint="/">
      <div class="govuk-grid-row">

        <div class="govuk-grid-column-one-third app-filter-panel">
          <div class="app-search-box app-search-box--sidebar">
            <label for="search-input" class="govuk-label">Search</label>
            <div class="app-search-box__group">
              <input
                class="govuk-input app-search-box__input"
                id="search-input"
                name="q"
                type="search"
                value="{{ searchQuery }}"
                spellcheck="false"
              >
              <button type="submit" class="govuk-button app-search-box__button" data-module="govuk-button">
                <svg class="app-search-box__icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                  <circle cx="7.5" cy="7.5" r="6" stroke="currentColor" stroke-width="2"/>
                  <line x1="12" y1="12" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span class="govuk-visually-hidden">Search</span>
              </button>
            </div>
          </div>

          <div id="search-filters" class="app-search-region">
            {% include "search/_filters.njk" %}
          </div>
        </div>

        <div id="search-results" class="govuk-grid-column-two-thirds app-search-region">
          {% include "search/_results-column.njk" %}
        </div>

      </div>
    </form>
  </div>
{% endblock %}
